{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug httpd98",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/httpd98",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "build",
            "stopAtEntry": false,
            "setupCommands": [
                { "text": "-enable-pretty-printing", "ignoreFailures": true },
            ],
        }
    ]
}
