{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug httpd98",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/httpd98",
            "cwd": "${workspaceFolder}",
            "MIMode": "gdb",
            "preLaunchTask": "build",
            "stopAtEntry": false,
            "linux": {
                "MIMode": "gdb",
                "setupCommands": [
                    { "text": "-enable-pretty-printing", "ignoreFailures": true },
                    { "text": "set follow-fork-mode child" }
                ],
            },
            "osx": {
                "MIMode": "lldb"
            }
        }
    ]
}
